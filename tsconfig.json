{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "hardhat"]
  },
  "include": ["src", "scripts", "examples", "demo", "api", "test", "hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
